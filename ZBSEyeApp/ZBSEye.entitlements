<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- NO com.apple.security.app-sandbox: SCK full-display + cross-app AX + local server
	     are incompatible with the App Sandbox. Hardened Runtime without sandbox (the recorder class like Rewind). -->
	<!-- Microphone under Hardened Runtime (step 10): audio capture for on-device transcription. -->
	<key>com.apple.security.device.audio-input</key>
	<true/>
</dict>
</plist>
