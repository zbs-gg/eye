            "value": "ZBS Eye записывает и расшифровывает звук локально, чтобы по разговорам можно было искать."
          }
        }
      }
    },
    "ZBS Eye recognizes speech on-device to make audio searchable.": {
      "localizations": {
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "ZBS Eye распознаёт речь на устройстве, чтобы по звуку можно было искать."
          }
        }
      }
    },
    "Language": {
      "localizations": {
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Язык"
          }
        }
      }
    },
