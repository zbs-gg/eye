      "localizations": {
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Галактика дня"
          }
        }
      }
    },
    "Thirty different apps in a day. This isn't a constellation anymore — it's a swirling galaxy. Phew.": {
      "localizations": {
        "ru": {
          "stringUnit": {
            "state": "translated",
