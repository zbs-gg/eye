      "localizations": {
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Уходя под свет"
          }
        }
      }
    },
    "45 minutes without a break — you descended beneath the first rays.": {
      "localizations": {
        "ru": {
