    },
    "Defocus": {
      "localizations": {
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Расфокус"
          }
        }
      }
    },
    "Squirrel in a Wheel": {
      "localizations": {
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Белка в колесе"
          }
        }
      }
    },
    "150 switches in a day — the squirrel's off and running.": {
      "localizations": {
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "150 переключений за день — побежала белка."
          }
        }
      }
    },
    "Carousel of Context": {
      "localizations": {
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Карусель контекста"
          }
