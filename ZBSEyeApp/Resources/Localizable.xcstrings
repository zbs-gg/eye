            "state": "translated",
            "value": "Звёздное скопление"
          }
        }
      }
    },
    "Twenty apps — the sky is packed with a dense, glowing cluster of stars. It was a full day.": {
      "localizations": {
        "ru": {
          "stringUnit": {
            "state": "translated",
