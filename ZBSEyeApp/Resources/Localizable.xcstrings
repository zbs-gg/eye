          "stringUnit": {
            "state": "translated",
            "value": "Перегрев турбины"
          }
        }
      }
    },
    "40 000 frames in a day — the reactor in the red zone, did you even sleep?": {
      "localizations": {
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "40 000 кадров за день — реактор на красной зоне, ты вообще спал?"
          }
