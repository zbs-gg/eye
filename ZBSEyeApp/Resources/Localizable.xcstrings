          "stringUnit": {
            "state": "translated",
            "value": "Часовой механизм"
          }
        }
      }
    },
    "15 000 frames in a day — the whole mechanism is running.": {
      "localizations": {
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "15 000 кадров за день — заработал весь механизм."
          }
        }
      }
    },
    "Full Throttle": {
      "localizations": {
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Полный газ"
          }
        }
      }
    },
    "25 000 frames in a day — the engine at full.": {
      "localizations": {
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "25 000 кадров за день — двигатель на максимум."
          }
        }
      }
    },
    "Turbine Overheat": {
      "localizations": {
