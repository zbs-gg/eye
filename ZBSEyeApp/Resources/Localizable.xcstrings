    "Three Fires": {
      "localizations": {
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Три огня"
          }
        }
      }
    },
    "Three different apps in a day. Three lone stars lit up in the dark.": {
      "localizations": {
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "За день — три разных приложения. Три одиноких звезды загорелись в темноте."
          }
        }
      }
    },
    "Constellation": {
      "localizations": {
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Созвездие"
          }
        }
